:root, :host {
  --fa-font-light: normal 300 1em/1 "Font Awesome 6 Pro"; }

@font-face {
  font-family: 'Font Awesome 6 Pro';
  font-style: normal;
  font-weight: 300;
  font-display: block;
  src: url("https://import.cdn.thinkific.com/244754/courses/1825320/falight300-220417-085240.woff2") format("woff2"), 
  url("https://import.cdn.thinkific.com/244754/courses/1825320/falight300-220417-085240.ttf") format("truetype"); }

.fal,
.fa-light {
  font-family: 'Font Awesome 6 Pro';
  font-weight: 300; }
